{
  "editionId": "1.9.4-blackwing",
  "minecraftVersion": "1.9.4",
  "recommendedOptiFineBuild": "OptiFine_1.9.4_HD_U_I5",
  "steps": [
    {
      "id": "verify-optifine",
      "action": "validate-user-runtime-input",
      "expects": "OptiFine_1.9.4_HD_U_*.jar"
    },
    {
      "id": "overlay-instance",
      "action": "merge-directory",
      "source": "instance/.minecraft",
      "target": ".minecraft"
    },
    {
      "id": "copy-runtime",
      "action": "copy-user-optifine-jar",
      "target": "runtime/optifine"
    },
    {
      "id": "activate-profile",
      "action": "select-profile",
      "profileId": "arena"
    }
  ],
  "postInstallHints": [
    "Keep attack indicator enabled for 1.9 combat readability.",
    "Leave shaders off and dynamic lights disabled for better frametime consistency.",
    "Use 7 chunks render distance as the balanced default."
  ]
}
